NODE_ENV=development
PORT=4400
FRONTEND_URL=http://127.0.0.1:5173,http://127.0.0.1:5174
DATABASE_URL=postgresql://postgres:change-me@127.0.0.1:5432/orbit
JWT_SECRET=replace-with-at-least-32-random-characters
CREDENTIAL_ENCRYPTION_KEY=replace-with-a-64-character-hex-key
DEMO_MODE=true
ALLOW_DEVELOPMENT_SEED=false
SEED_DATABASE_NAME=orbit
SFTP_ALLOW_PRIVATE_NETWORKS=false
MAX_FILE_BYTES=2097152
LOG_LEVEL=info

# Canonical public origin used to build emailed links. Falls back to the first
# FRONTEND_URL entry, which is only correct when that list has one value.
APP_URL=http://127.0.0.1:5173

# Transactional email. With no API key the transport logs the message and its
# link to the console instead of sending, so the flows are testable locally.
RESEND_API_KEY=
EMAIL_FROM=Orbit+ <onboarding@resend.dev>

# Access tokens are short-lived because clients hold a rotating refresh token.
# Payments. Leave blank to run without a processor: billing routes report a
# clear 503 and the self-hosted downgrade path stays available.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_PRO=

# Uploads bypass version history, so they may exceed the editor limit.
MAX_UPLOAD_BYTES=104857600
MAX_VERSIONED_UPLOAD_BYTES=10485760

ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL_DAYS=30
PASSWORD_RESET_TTL_MINUTES=60
EMAIL_VERIFICATION_TTL_HOURS=24
